---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import '../../styles/blogIndex.css';
import '../../styles/single-post.css';

const sortedPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = await Promise.all(
  sortedPosts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return {
      ...post,
      minutesRead: remarkPluginFrontmatter.minutesRead,
    };
  })
);

const [featured, ...rest] = posts;

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
}
---

<Layout>
  <Nav/>
  <section class="hero">
    <div class="wrap hero-inner">
      <span class="pill">From the datsenglish coach</span>
      <h1>Read the docs.<br>Not the <span class="accent">translation.</span></h1>
      <p>Weekly breakdowns on tech English, docs, interviews, and the mindset that gets Portuguese-speaking devs unstuck. Real material. No fluff.</p>

      <div class="filters">
        <button class="chip is-active" data-tag="all">#all</button>
        {allTags.map((tag) => (
          <button class="chip" data-tag={tag}>#{tag}</button>
        ))}
      </div>
    </div>
  </section>

  {featured && (
    <section class="featured">
      <div class="wrap">
        <a href={`/blog/${featured.id}/`} class="featured-card">
          <div class="featured-visual">
            <span class="tag">FEATURED · {featured.data.tags[0].toUpperCase()}</span>
            <span class="glyph">Aa→Bb</span>
          </div>
          <div class="featured-text">
            <span class="meta">{formatDate(featured.data.pubDate)} · {featured.minutesRead}</span>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.description}</p>
            <span class="read-link">Read the article <span class="arrow">→</span></span>
          </div>
        </a>
      </div>
    </section>
  )}

  <section class="grid-section">
    <div class="wrap">
      <div class="grid-heading">
        <h3>More from the blog</h3>
        <span>{rest.length} posts</span>
      </div>

      <div class="post-grid">
        {rest.map((post, i) => (
          <a href={`/blog/${post.id}/`} class={`post-card c${(i % 6) + 1}`} data-tags={post.data.tags.join(',')}>
            <div class="block"><span class="tag-ribbon">#{post.data.tags[0]}</span></div>
            <div class="body">
              <h4>{post.data.title}</h4>
              <p>{post.data.description}</p>
              <div class="foot"><span>{formatDate(post.data.pubDate)}</span><span>{post.minutesRead}</span></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="wrap">
      <h2>Ready to stop translating <br>and start <span class="lime">building?</span></h2>
      <p>20-minute discovery call. We'll find exactly where the language wall is hitting you.</p>
      <a href="#" class="btn btn-lime">Book your free call</a>
    </div>
  </section>

  <Footer/>
</Layout>

<script>
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('is-active'));
      chip.classList.add('is-active');

      const selected = chip.getAttribute('data-tag');
      document.querySelectorAll('.post-card').forEach((card) => {
        const cardTags = card.getAttribute('data-tags')?.split(',') ?? [];
        const show = selected === 'all' || cardTags.includes(selected!);
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>