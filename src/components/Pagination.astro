---
interface Props {
  page: {
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string };
  };
}

const { page } = Astro.props;
---

{page.lastPage > 1 && (
  <nav class="pagination" aria-label="Pagination">
    {page.url.prev
      ? <a href={page.url.prev} class="page-link">← Newer</a>
      : <span class="page-link is-disabled">← Newer</span>}

    <span class="page-status">Page {page.currentPage} of {page.lastPage}</span>

    {page.url.next
      ? <a href={page.url.next} class="page-link">Older →</a>
      : <span class="page-link is-disabled">Older →</span>}
  </nav>
)}